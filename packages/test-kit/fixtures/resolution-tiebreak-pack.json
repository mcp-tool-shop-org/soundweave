{
  "meta": {
    "id": "resolution-tiebreak",
    "name": "Resolution Tiebreak",
    "version": "1.0.0",
    "schemaVersion": "1"
  },
  "assets": [
    { "id": "a1", "name": "Loop A", "src": "audio/a.ogg", "kind": "loop", "durationMs": 8000 },
    { "id": "a2", "name": "Loop B", "src": "audio/b.ogg", "kind": "loop", "durationMs": 8000 }
  ],
  "stems": [
    { "id": "s1", "name": "Stem A", "assetId": "a1", "role": "base", "loop": true },
    { "id": "s2", "name": "Stem B", "assetId": "a2", "role": "base", "loop": true }
  ],
  "scenes": [
    {
      "id": "sc-first",
      "name": "First Scene",
      "category": "exploration",
      "layers": [{ "stemId": "s1" }]
    },
    {
      "id": "sc-second",
      "name": "Second Scene",
      "category": "exploration",
      "layers": [{ "stemId": "s2" }]
    }
  ],
  "bindings": [
    {
      "id": "b-first",
      "name": "First bind",
      "sceneId": "sc-first",
      "conditions": [{ "field": "mode", "op": "eq", "value": "exploration" }],
      "priority": 10
    },
    {
      "id": "b-second",
      "name": "Second bind",
      "sceneId": "sc-second",
      "conditions": [{ "field": "mode", "op": "eq", "value": "exploration" }],
      "priority": 10
    }
  ],
  "transitions": []
}
