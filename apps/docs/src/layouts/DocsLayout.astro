---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Soundweave Docs</title>
    <style>
      :root {
        --bg: #0d1117;
        --bg-surface: #161b22;
        --text: #c9d1d9;
        --text-bright: #f0f6fc;
        --text-dim: #8b949e;
        --accent: #58a6ff;
        --border: #30363d;
        --radius: 6px;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica,
          Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }

      .docs-shell {
        display: grid;
        grid-template-columns: 220px 1fr;
        min-height: 100vh;
      }

      .docs-nav {
        background: var(--bg-surface);
        border-right: 1px solid var(--border);
        padding: 24px 16px;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
      }

      .docs-nav-brand {
        font-size: 16px;
        font-weight: 700;
        color: var(--text-bright);
        margin-bottom: 24px;
      }

      .docs-nav-brand a {
        color: inherit;
        text-decoration: none;
      }

      .docs-nav ul {
        list-style: none;
      }

      .docs-nav li {
        margin-bottom: 4px;
      }

      .docs-nav a {
        display: block;
        padding: 6px 10px;
        border-radius: var(--radius);
        color: var(--text-dim);
        text-decoration: none;
        font-size: 14px;
        transition: background 0.15s, color 0.15s;
      }

      .docs-nav a:hover {
        background: rgba(88, 166, 255, 0.08);
        color: var(--text);
      }

      .docs-nav a.active {
        background: rgba(88, 166, 255, 0.15);
        color: var(--accent);
        font-weight: 600;
      }

      .docs-main {
        padding: 48px 64px;
        max-width: 820px;
      }

      .docs-main h1 {
        font-size: 32px;
        font-weight: 700;
        color: var(--text-bright);
        margin-bottom: 8px;
      }

      .docs-main h2 {
        font-size: 22px;
        font-weight: 600;
        color: var(--text-bright);
        margin-top: 40px;
        margin-bottom: 12px;
        padding-bottom: 6px;
        border-bottom: 1px solid var(--border);
      }

      .docs-main h3 {
        font-size: 17px;
        font-weight: 600;
        color: var(--text-bright);
        margin-top: 28px;
        margin-bottom: 8px;
      }

      .docs-main p {
        margin-bottom: 16px;
      }

      .docs-main ul,
      .docs-main ol {
        margin-bottom: 16px;
        padding-left: 24px;
      }

      .docs-main li {
        margin-bottom: 6px;
      }

      .docs-main code {
        font-family: "JetBrains Mono", "Fira Code", monospace;
        font-size: 0.9em;
        padding: 2px 6px;
        border-radius: 3px;
        background: var(--bg-surface);
        color: var(--accent);
      }

      .docs-main pre {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px;
        overflow-x: auto;
        margin-bottom: 16px;
        font-size: 13px;
        line-height: 1.5;
      }

      .docs-main pre code {
        padding: 0;
        background: none;
        color: var(--text);
      }

      .docs-subtitle {
        font-size: 16px;
        color: var(--text-dim);
        margin-bottom: 32px;
      }

      .docs-main strong {
        color: var(--text-bright);
      }

      .docs-main table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 16px;
      }

      .docs-main th,
      .docs-main td {
        text-align: left;
        padding: 8px 12px;
        border-bottom: 1px solid var(--border);
        font-size: 14px;
      }

      .docs-main th {
        color: var(--text-bright);
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <div class="docs-shell">
      <nav class="docs-nav">
        <div class="docs-nav-brand"><a href="/">⚡ Soundweave</a></div>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/getting-started">Getting Started</a></li>
          <li><a href="/core-concepts">Core Concepts</a></li>
          <li><a href="/workflow">Workflow</a></li>
          <li><a href="/examples">Examples</a></li>
        </ul>
      </nav>
      <main class="docs-main">
        <slot />
      </main>
    </div>
  </body>
</html>
